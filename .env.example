# ─────────────────────────────────────────────────────────────────────────────
# Mini Sentinel Pipeline – Environment Variables
# Copy this file to `.env` and fill in your actual keys.
# ─────────────────────────────────────────────────────────────────────────────

# --- LLM Provider (choose: "openrouter" | "openai" | "anthropic") ---
LLM_PROVIDER=openrouter

# --- OpenRouter (default) ---
OPENROUTER_API_KEY=sk-or-v1
OPENROUTER_MODEL=qwen/qwen3-coder:free

# --- OpenAI (only needed when LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...

# --- Anthropic (only needed when LLM_PROVIDER=anthropic) ---
# ANTHROPIC_API_KEY=sk-ant-...
